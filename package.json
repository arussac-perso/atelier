{
  "name": "atelier",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "backend:dev": "cd backend && uvicorn main:app --reload --port 8000",
    "dev:backend": "cd backend && uvicorn main:app --reload --port 8000",
    "dev:frontend": "vite",
    "dev:all": "concurrently -n BACK,FRONT -c cyan,green \"npm run backend:dev\" \"npm run dev:frontend\""
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "react": "^18",
    "react-dom": "^18",
    "react-router-dom": "^6",
    "zustand": "^4",
    "@tanstack/react-query": "^5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4",
    "typescript": "^5",
    "vite": "^5",
    "concurrently": "^8"
  }
}
